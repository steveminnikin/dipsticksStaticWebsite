---
const currentPath = Astro.url.pathname;

const navItems = [
  { label: 'Home', href: '/' },
  {
    label: 'Products',
    children: [
      { label: 'Dipsticks', href: '/products/dipsticks/' },
      { label: 'Dip Tapes', href: '/products/dip-tapes/' },
      { label: 'Calibration Charts', href: '/products/calibration-charts/' },
    ],
  },
  { label: 'About', href: '/about/' },
  { label: 'FAQs', href: '/faqs/' },
  {
    label: 'Guides',
    children: [
      { label: 'How to Use a Dipstick', href: '/guides/how-to-use-a-dipstick/' },
      { label: 'Dipstick Rubbing Guide', href: '/guides/dipstick-rubbing-guide/' },
    ],
  },
  { label: 'Contact', href: '/contact/' },
];

function isActive(href: string): boolean {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}

function hasActiveChild(children: { href: string }[]): boolean {
  return children.some((child) => isActive(child.href));
}
---

<header class="sticky top-0 z-50 bg-white border-b border-neutral-200 shadow-sm">
  <!-- Top bar (desktop only) -->
  <div class="hidden lg:block bg-primary text-white">
    <div class="mx-auto max-w-7xl px-4 py-2 flex justify-between items-center text-sm">
      <p class="font-medium">Fuel tank measuring solutions — over 35 years of expertise</p>
      <div class="flex items-center gap-6">
        <a href="mailto:enquiries@dipsticksengineering.co.uk" class="hover:text-secondary transition-colors flex items-center gap-2">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" /></svg>
          enquiries@dipsticksengineering.co.uk
        </a>
        <a href="tel:03335671654" class="hover:text-secondary transition-colors flex items-center gap-2">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" /></svg>
          0333 567 1654
        </a>
      </div>
    </div>
  </div>

  <!-- Main nav -->
  <nav class="mx-auto max-w-7xl px-4" aria-label="Main navigation">
    <div class="flex items-center justify-between h-16 lg:h-18">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 text-primary font-bold text-xl lg:text-2xl">
        <span>Dipsticks</span>
        <span class="font-normal text-neutral-500">Engineering</span>
      </a>

      <!-- Desktop nav -->
      <ul class="hidden lg:flex items-center gap-1">
        {navItems.map((item) => (
          'children' in item && item.children ? (
            <li class="relative group">
              <button
                class={`px-3 py-2 rounded-md text-sm font-medium transition-colors inline-flex items-center gap-1 ${
                  hasActiveChild(item.children)
                    ? 'text-primary bg-secondary/30'
                    : 'text-neutral-700 hover:text-primary hover:bg-neutral-100'
                }`}
                aria-expanded="false"
                aria-haspopup="true"
              >
                {item.label}
                <svg class="w-4 h-4 transition-transform group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" /></svg>
              </button>
              <ul class="absolute top-full left-0 mt-1 w-56 bg-white rounded-lg shadow-lg border border-neutral-200 py-1 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-150 z-50">
                {item.children.map((child) => (
                  <li>
                    <a
                      href={child.href}
                      class={`block px-4 py-2 text-sm transition-colors ${
                        isActive(child.href)
                          ? 'text-primary bg-secondary/20 font-medium'
                          : 'text-neutral-700 hover:text-primary hover:bg-neutral-50'
                      }`}
                    >
                      {child.label}
                    </a>
                  </li>
                ))}
              </ul>
            </li>
          ) : (
            <li>
              <a
                href={item.href}
                class={`px-3 py-2 rounded-md text-sm font-medium transition-colors ${
                  isActive(item.href!)
                    ? 'text-primary bg-secondary/30'
                    : 'text-neutral-700 hover:text-primary hover:bg-neutral-100'
                }`}
              >
                {item.label}
              </a>
            </li>
          )
        ))}
        <li>
          <a href="/request-a-quote/" class="ml-2 inline-flex items-center px-4 py-2 bg-accent hover:bg-accent-dark text-white text-sm font-semibold rounded-lg transition-colors">
            Get a Quote
          </a>
        </li>
      </ul>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class="lg:hidden p-2 rounded-md text-neutral-700 hover:bg-neutral-100 transition-colors"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg class="w-6 h-6" id="menu-icon-open" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" /></svg>
        <svg class="w-6 h-6 hidden" id="menu-icon-close" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
      </button>
    </div>

    <!-- Mobile nav -->
    <div id="mobile-menu" class="hidden lg:hidden pb-4 border-t border-neutral-200 mt-2 pt-4">
      <ul class="space-y-1">
        {navItems.map((item) => (
          'children' in item && item.children ? (
            <li>
              <button
                class="mobile-dropdown-btn w-full flex items-center justify-between px-3 py-2 rounded-md text-sm font-medium text-neutral-700 hover:bg-neutral-100 transition-colors"
                aria-expanded="false"
              >
                {item.label}
                <svg class="w-4 h-4 transition-transform" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" /></svg>
              </button>
              <ul class="hidden pl-4 space-y-1 mt-1">
                {item.children.map((child) => (
                  <li>
                    <a
                      href={child.href}
                      class={`block px-3 py-2 rounded-md text-sm transition-colors ${
                        isActive(child.href)
                          ? 'text-primary bg-secondary/20 font-medium'
                          : 'text-neutral-600 hover:text-primary hover:bg-neutral-50'
                      }`}
                    >
                      {child.label}
                    </a>
                  </li>
                ))}
              </ul>
            </li>
          ) : (
            <li>
              <a
                href={item.href}
                class={`block px-3 py-2 rounded-md text-sm font-medium transition-colors ${
                  isActive(item.href!)
                    ? 'text-primary bg-secondary/30'
                    : 'text-neutral-700 hover:text-primary hover:bg-neutral-100'
                }`}
              >
                {item.label}
              </a>
            </li>
          )
        ))}
      </ul>
      <div class="mt-4 px-3">
        <a href="/request-a-quote/" class="block text-center px-4 py-2 bg-accent hover:bg-accent-dark text-white text-sm font-semibold rounded-lg transition-colors">
          Get a Quote
        </a>
      </div>
      <!-- Mobile contact info -->
      <div class="mt-4 px-3 pt-4 border-t border-neutral-200 space-y-2 text-sm text-neutral-600">
        <a href="tel:03335671654" class="flex items-center gap-2 hover:text-primary">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" /></svg>
          0333 567 1654
        </a>
        <a href="mailto:enquiries@dipsticksengineering.co.uk" class="flex items-center gap-2 hover:text-primary">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" /></svg>
          enquiries@dipsticksengineering.co.uk
        </a>
      </div>
    </div>
  </nav>
</header>

<script>
  // Mobile menu toggle
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');

  menuBtn?.addEventListener('click', () => {
    const isOpen = mobileMenu?.classList.toggle('hidden') === false;
    iconOpen?.classList.toggle('hidden', isOpen);
    iconClose?.classList.toggle('hidden', !isOpen);
    menuBtn.setAttribute('aria-expanded', String(isOpen));
  });

  // Mobile dropdown toggles
  document.querySelectorAll('.mobile-dropdown-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const submenu = btn.nextElementSibling;
      const isOpen = submenu?.classList.toggle('hidden') === false;
      btn.setAttribute('aria-expanded', String(isOpen));
      const arrow = btn.querySelector('svg');
      arrow?.classList.toggle('rotate-180', isOpen);
    });
  });
</script>
