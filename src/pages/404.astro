---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page Not Found"
  description="The page you're looking for doesn't exist."
  noindex={true}
>
  <section class="py-20 lg:py-32">
    <div class="mx-auto max-w-7xl px-4 text-center">
      <p class="text-6xl font-bold text-primary">404</p>
      <h1 class="mt-4 text-2xl sm:text-3xl font-bold text-neutral-900">Page not found</h1>
      <p class="mt-3 text-neutral-600 max-w-md mx-auto">
        Sorry, the page you're looking for doesn't exist or has been moved. Try one of the links below.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href="/" class="inline-flex items-center px-6 py-3 bg-primary hover:bg-primary-light text-white font-semibold rounded-lg transition-colors">
          Go Home
        </a>
        <a href="/contact/" class="inline-flex items-center px-6 py-3 bg-white text-primary font-medium rounded-lg transition-colors border border-neutral-200 hover:border-primary/20 hover:shadow-md">
          Contact Us
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
