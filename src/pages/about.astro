---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';

const stats = [
  { value: '35+', label: 'Years of experience' },
  { value: '1000s', label: 'Dipsticks manufactured' },
  { value: '5', label: 'Tank types we calibrate' },
  { value: '6+', label: 'Liquid types we measure' },
];
---

<BaseLayout
  title="About Us — Storage Tank Calibration Specialists"
  description="Dipsticks Engineering has over 35 years of specialist experience in the calibration and manufacture of dipsticks, dip tapes and calibration charts for liquid storage tanks."
>
  <PageHeader
    title="About Dipsticks Engineering"
    subtitle="Over 35 years of specialist experience in tank measurement"
    breadcrumbs={[
      { label: 'Home', href: '/' },
      { label: 'About Us' },
    ]}
  />

  <!-- Stats -->
  <section class="py-12 bg-white border-b border-neutral-200">
    <div class="mx-auto max-w-7xl px-4">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
        {stats.map((stat) => (
          <div>
            <p class="text-3xl font-bold text-primary">{stat.value}</p>
            <p class="mt-1 text-sm text-neutral-600">{stat.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Main content -->
  <section class="py-12 lg:py-16">
    <div class="mx-auto max-w-7xl px-4">
      <div class="max-w-3xl mx-auto space-y-6 text-neutral-600 leading-relaxed">
        <h2 class="text-2xl font-bold text-neutral-900">Who We Are</h2>
        <p>
          Dipsticks Engineering has <strong>over 35 years of specialist experience</strong> in the calibration and manufacture of dipsticks and calibration charts for liquid storage tanks.
        </p>
        <p>
          Whether you are a tank manufacturer, a garage forecourt supplier or rely on storage tanks for the running of your business or home, we can provide you with high precision volume measurement at low cost.
        </p>

        <h2 class="text-2xl font-bold text-neutral-900 pt-4">What We Do</h2>
        <p>
          We manufacture calibrated dipsticks, dip tapes and strapping tables (calibration charts) for above and below ground fuel storage tanks. Our products measure the volume of liquid in storage tanks containing oil, diesel, petrol, kerosene, hydraulic fluid and other non-consumption liquids.
        </p>
        <p>
          You may be conducting a large tank installation project or run a service station — either way, we can provide you with a dipstick for the largest underground industrial tank to a recycled oil drum and everything in between.
        </p>

        <h2 class="text-2xl font-bold text-neutral-900 pt-4">Our Expertise</h2>
        <p>
          With such a long involvement in the industry we have built up a <strong>vast database of tanks</strong>. There's a good chance we already know your tank details, even if you don't!
        </p>
        <p>
          Unlike other manufacturers, our volumetric calculations take into account <strong>real-world tank design and manufacture</strong>, so you can be confident that whether your tank has dished ends, is on a tilt or is something more exotic, the volume measurements from our dipsticks will be highly accurate.
        </p>

        <h2 class="text-2xl font-bold text-neutral-900 pt-4">Our Products</h2>
        <p>
          Our dipsticks are manufactured from T-section GRP (Glass Reinforced Plastic) making them durable yet flexible and ideally suited for use in demanding environments. We also provide dip tapes for tanks where a dipstick is impractical, and strapping tables for quick volume conversion from depth readings.
        </p>
        <p>
          Every product is manufactured to your exact specifications and can be customised with tank references, telephone numbers or any other details you require.
        </p>

        <h2 class="text-2xl font-bold text-neutral-900 pt-4">Quality and Standards</h2>
        <p>
          Our products are manufactured using specially formulated GRP mixtures ensuring the correct electrical and thermal properties in accordance with BSI regulations. Our dip tapes meet EC Class II accuracy standards.
        </p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-primary">
    <div class="mx-auto max-w-7xl px-4 py-12 text-center">
      <h2 class="text-2xl font-bold text-white">Ready to get started?</h2>
      <p class="mt-2 text-secondary max-w-lg mx-auto">
        Contact us with your tank details for a no-obligation quote.
      </p>
      <div class="mt-6 flex flex-wrap justify-center gap-4">
        <a href="/contact/" class="inline-flex items-center px-6 py-3 bg-accent hover:bg-accent-dark text-white font-semibold rounded-lg transition-colors">
          Get a Quote
        </a>
        <a href="tel:03335671654" class="inline-flex items-center gap-2 px-6 py-3 bg-white/10 hover:bg-white/20 text-white font-medium rounded-lg transition-colors border border-white/20">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" /></svg>
          Call 0333 567 1654
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
