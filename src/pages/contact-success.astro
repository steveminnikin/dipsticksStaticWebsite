---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
---

<BaseLayout
  title="Message Sent"
  description="Thank you — we've received your message and will be in touch shortly."
>
  <PageHeader
    title="Message Sent"
    subtitle="Thank you for getting in touch"
    breadcrumbs={[
      { label: 'Home', href: '/' },
      { label: 'Contact', href: '/contact/' },
      { label: 'Success' },
    ]}
  />

  <section class="py-16 lg:py-24">
    <div class="mx-auto max-w-2xl px-4 text-center">
      <div class="bg-white rounded-xl border border-neutral-200 p-8 lg:p-12">
        <div class="mx-auto w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mb-6">
          <svg class="w-8 h-8 text-green-600" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
          </svg>
        </div>

        <h2 class="text-2xl font-bold text-neutral-900 mb-3">We've received your message</h2>
        <p class="text-neutral-600 mb-8">
          Thank you for contacting us. We'll get back to you as soon as possible, usually within one working day.
        </p>

        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="/" class="px-6 py-2.5 bg-primary hover:bg-primary-dark text-white font-semibold rounded-lg transition-colors">
            Back to Home
          </a>
          <a href="/contact/" class="px-6 py-2.5 border border-neutral-300 hover:border-primary text-neutral-700 hover:text-primary font-medium rounded-lg transition-colors">
            Send Another Message
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
