---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
---

<BaseLayout
  title="Contact Us"
  description="Get in touch with Dipsticks Engineering for a quote or enquiry. Call 0333 567 1654 or email enquiries@dipsticksengineering.co.uk. Based in Hinstock, Shropshire."
>
  <PageHeader
    title="Contact Us"
    subtitle="Get in touch for a quote or with any questions"
    breadcrumbs={[
      { label: 'Home', href: '/' },
      { label: 'Contact' },
    ]}
  />

  <section class="py-12 lg:py-16">
    <div class="mx-auto max-w-7xl px-4">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-8 lg:gap-12">
        <!-- Form -->
        <div class="lg:col-span-3">
          <div class="bg-white rounded-xl border border-neutral-200 p-6 lg:p-8">
            <h2 class="text-xl font-semibold text-neutral-900 mb-6">Send us a message</h2>

            <form
              name="contact"
              method="POST"
              data-netlify="true"
              netlify-honeypot="bot-field"
              class="space-y-5"
            >
              <input type="hidden" name="form-name" value="contact" />
              <p class="hidden">
                <label>Don't fill this out: <input name="bot-field" /></label>
              </p>

              <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                <div>
                  <label for="name" class="block text-sm font-medium text-neutral-700 mb-1">Name <span class="text-error">*</span></label>
                  <input
                    type="text"
                    id="name"
                    name="name"
                    required
                    autocomplete="name"
                    class="w-full px-4 py-2.5 border border-neutral-300 rounded-lg text-neutral-900 placeholder-neutral-400 focus:border-primary focus:ring-2 focus:ring-primary/20 transition-colors"
                    placeholder="Your name"
                  />
                </div>
                <div>
                  <label for="company" class="block text-sm font-medium text-neutral-700 mb-1">Company</label>
                  <input
                    type="text"
                    id="company"
                    name="company"
                    autocomplete="organization"
                    class="w-full px-4 py-2.5 border border-neutral-300 rounded-lg text-neutral-900 placeholder-neutral-400 focus:border-primary focus:ring-2 focus:ring-primary/20 transition-colors"
                    placeholder="Your company (optional)"
                  />
                </div>
              </div>

              <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                <div>
                  <label for="email" class="block text-sm font-medium text-neutral-700 mb-1">Email <span class="text-error">*</span></label>
                  <input
                    type="email"
                    id="email"
                    name="email"
                    required
                    autocomplete="email"
                    class="w-full px-4 py-2.5 border border-neutral-300 rounded-lg text-neutral-900 placeholder-neutral-400 focus:border-primary focus:ring-2 focus:ring-primary/20 transition-colors"
                    placeholder="your@email.co.uk"
                  />
                </div>
                <div>
                  <label for="phone" class="block text-sm font-medium text-neutral-700 mb-1">Phone</label>
                  <input
                    type="tel"
                    id="phone"
                    name="phone"
                    autocomplete="tel"
                    class="w-full px-4 py-2.5 border border-neutral-300 rounded-lg text-neutral-900 placeholder-neutral-400 focus:border-primary focus:ring-2 focus:ring-primary/20 transition-colors"
                    placeholder="Your phone number"
                  />
                </div>
              </div>

              <div>
                <label for="subject" class="block text-sm font-medium text-neutral-700 mb-1">Enquiry Type</label>
                <select
                  id="subject"
                  name="subject"
                  class="w-full px-4 py-2.5 border border-neutral-300 rounded-lg text-neutral-900 focus:border-primary focus:ring-2 focus:ring-primary/20 transition-colors bg-white"
                >
                  <option value="quote">Request a Quote</option>
                  <option value="dipstick">Dipstick Enquiry</option>
                  <option value="dip-tape">Dip Tape Enquiry</option>
                  <option value="calibration-chart">Calibration Chart Enquiry</option>
                  <option value="replacement">Replacement Dipstick</option>
                  <option value="general">General Enquiry</option>
                </select>
              </div>

              <div>
                <label for="message" class="block text-sm font-medium text-neutral-700 mb-1">Message <span class="text-error">*</span></label>
                <textarea
                  id="message"
                  name="message"
                  required
                  rows="5"
                  class="w-full px-4 py-2.5 border border-neutral-300 rounded-lg text-neutral-900 placeholder-neutral-400 focus:border-primary focus:ring-2 focus:ring-primary/20 transition-colors resize-y"
                  placeholder="Please include your tank details if requesting a quote (tank type, dimensions, liquid type, etc.)"
                ></textarea>
              </div>

              <button
                type="submit"
                class="w-full sm:w-auto px-8 py-3 bg-accent hover:bg-accent-dark text-white font-semibold rounded-lg transition-colors"
              >
                Send Message
              </button>
            </form>
          </div>
        </div>

        <!-- Contact info -->
        <div class="lg:col-span-2 space-y-6">
          <div class="bg-white rounded-xl border border-neutral-200 p-6">
            <h3 class="font-semibold text-neutral-900 mb-4">Contact Details</h3>
            <div class="space-y-4">
              <div class="flex items-start gap-3">
                <svg class="w-5 h-5 text-primary mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" /></svg>
                <div>
                  <p class="text-sm font-medium text-neutral-900">Phone</p>
                  <a href="tel:03335671654" class="text-sm text-primary hover:underline">0333 567 1654</a>
                </div>
              </div>

              <div class="flex items-start gap-3">
                <svg class="w-5 h-5 text-primary mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" /></svg>
                <div>
                  <p class="text-sm font-medium text-neutral-900">Email</p>
                  <a href="mailto:enquiries@dipsticksengineering.co.uk" class="text-sm text-primary hover:underline">enquiries@dipsticksengineering.co.uk</a>
                </div>
              </div>

              <div class="flex items-start gap-3">
                <svg class="w-5 h-5 text-primary mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" /></svg>
                <div>
                  <p class="text-sm font-medium text-neutral-900">Address</p>
                  <address class="not-italic text-sm text-neutral-600">
                    The Lodge, Wood Lane<br />
                    Hinstock, Shropshire<br />
                    TF9 2TA
                  </address>
                </div>
              </div>

              <div class="flex items-start gap-3">
                <svg class="w-5 h-5 text-primary mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                <div>
                  <p class="text-sm font-medium text-neutral-900">Opening Hours</p>
                  <p class="text-sm text-neutral-600">Monday – Friday: 9am – 5pm</p>
                </div>
              </div>
            </div>
          </div>

          <div class="bg-primary/5 rounded-xl border border-primary/20 p-6">
            <h3 class="font-semibold text-neutral-900 mb-2">Requesting a Quote?</h3>
            <p class="text-sm text-neutral-600 mb-3">Use our dedicated quote form to provide your tank details and get an accurate price.</p>
            <a href="/request-a-quote/" class="inline-flex items-center gap-2 px-4 py-2.5 bg-accent hover:bg-accent-dark text-white text-sm font-semibold rounded-lg transition-colors">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m3.75 9v6m3-3H9m1.5-12H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" /></svg>
              Request a Quote
            </a>
            <p class="mt-3 text-sm text-neutral-600">
              Or download our <a href="/downloads/DipsticksTankMeasurementsForm.pdf" target="_blank" class="text-primary font-medium hover:underline">Tank Measurement Guide</a> for reference.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
