---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';

const faqs = [
  {
    question: 'What is a dipstick?',
    answer: 'A dipstick is a calibrated rod, manufactured from T-section GRP (Glass Reinforced Plastic), that is inserted into a storage tank to measure the volume of liquid inside. Each dipstick is custom-made to the exact dimensions of your tank, with volume markings engraved along its length.',
  },
  {
    question: 'How accurate are your dipsticks?',
    answer: 'Our dipsticks are highly accurate because our volumetric calculations take into account real-world tank design and manufacture. Whether your tank has dished ends, is on a tilt, or has an unusual shape, we can account for it. Our dip tapes meet EC Class II accuracy standards.',
  },
  {
    question: 'What types of tanks can you calibrate?',
    answer: 'We can calibrate virtually any type of liquid storage tank including rectangular tanks, horizontal cylindrical tanks (with or without dished ends), vertical cylindrical tanks, home heating oil tanks, and oil drums. If you have an unusual tank shape, <a href="/contact/">contact us</a> — we have over 35 years of experience with all kinds of tanks.',
  },
  {
    question: 'What liquids are your products suitable for?',
    answer: 'Our products are suitable for all non-consumption liquids including oil, diesel (DERV), petrol, paraffin, kerosene, gas oil, and hydraulic fluid.',
  },
  {
    question: 'I don\'t know the dimensions of my tank. Can you still help?',
    answer: 'Yes! With over 35 years in the industry, we have built up a vast database of tanks. There\'s a good chance we already have your tank details on file. Alternatively, if you have an existing dipstick (even a broken one), you can send us a <a href="/guides/dipstick-rubbing-guide/">rubbing</a> and we can manufacture a replacement.',
  },
  {
    question: 'What is a strapping table?',
    answer: 'A strapping table (also known as a <a href="/products/calibration-charts/">calibration chart</a>) displays the same volume calculations as a dipstick, but in table format for quick reference. You use it together with a <a href="/products/dip-tapes/">dip tape</a> — measure the depth of liquid with the tape, then look up the corresponding volume on the table. We provide them in both durable hard copy and digital format.',
  },
  {
    question: 'How much do your dipsticks cost?',
    answer: 'Dipsticks start from £52 (ex VAT and delivery). Each dipstick is custom-manufactured to your tank dimensions, so the exact price depends on the length and your specific requirements. <a href="/request-a-quote/">Request a quote</a> for an accurate price.',
  },
  {
    question: 'Can you convert a gallons dipstick to litres?',
    answer: 'Yes. If you have an existing dipstick marked in gallons, you can send us a rubbing and we can manufacture a replacement marked in litres (or any other unit). See our <a href="/guides/dipstick-rubbing-guide/">rubbing guide</a> for instructions.',
  },
  {
    question: 'What units do you offer?',
    answer: 'We can calibrate in litres, gallons, US gallons, cubic metres, or regular height intervals such as millimetres or inches. We can also provide dual-unit markings.',
  },
  {
    question: 'How do I take a rubbing of an existing dipstick?',
    answer: 'You\'ll need a strip of paper (till roll is ideal), tape, and a pencil. Tape the paper to the base of the dipstick, stretch it along the length, and rub over the markings with the pencil. See our <a href="/guides/dipstick-rubbing-guide/">detailed rubbing guide</a> for full instructions.',
  },
  {
    question: 'How do I send you my tank details?',
    answer: 'The easiest way is to download our <a href="/downloads/DipsticksTankMeasurementsForm.pdf" target="_blank">Tank Measurement Guide (PDF)</a>, fill in your tank dimensions, and send it to us via email or post. Alternatively, just <a href="/contact/">contact us</a> by phone or email and we\'ll guide you through the process.',
  },
  {
    question: 'How long does delivery take?',
    answer: 'Lead times depend on the complexity of the order. <a href="/contact/">Contact us</a> for current lead times and we\'ll give you an estimated delivery date when we quote.',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.answer.replace(/<[^>]*>/g, ''),
    },
  })),
};
---

<BaseLayout
  title="Frequently Asked Questions"
  description="Common questions about dipsticks, dip tapes, strapping tables and storage tank calibration. Find answers about pricing, accuracy, tank types and ordering."
  jsonLd={faqSchema}
>
  <PageHeader
    title="Frequently Asked Questions"
    subtitle="Everything you need to know about our tank measurement products"
    breadcrumbs={[
      { label: 'Home', href: '/' },
      { label: 'FAQs' },
    ]}
  />

  <section class="py-12 lg:py-16">
    <div class="mx-auto max-w-3xl px-4">
      <div class="space-y-4">
        {faqs.map((faq) => (
          <details class="group bg-white rounded-xl border border-neutral-200 overflow-hidden">
            <summary class="flex items-center justify-between cursor-pointer p-5 text-left font-semibold text-neutral-900 hover:bg-neutral-50 transition-colors">
              <span class="pr-4">{faq.question}</span>
              <svg class="w-5 h-5 text-neutral-400 shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" /></svg>
            </summary>
            <div class="px-5 pb-5 text-neutral-600 leading-relaxed border-t border-neutral-100 pt-4 [&_a]:text-primary [&_a]:underline hover:[&_a]:no-underline">
              <p set:html={faq.answer} />
            </div>
          </details>
        ))}
      </div>

      <div class="mt-12 text-center bg-neutral-100 rounded-xl p-8">
        <h2 class="text-xl font-semibold text-neutral-900">Still have questions?</h2>
        <p class="mt-2 text-neutral-600">We're happy to help with any queries about our products.</p>
        <div class="mt-4 flex flex-wrap justify-center gap-4">
          <a href="/contact/" class="inline-flex items-center px-5 py-2.5 bg-primary hover:bg-primary-light text-white font-medium rounded-lg transition-colors text-sm">
            Contact Us
          </a>
          <a href="tel:03335671654" class="inline-flex items-center gap-2 px-5 py-2.5 bg-white text-neutral-700 font-medium rounded-lg transition-colors text-sm border border-neutral-200 hover:border-primary/20 hover:shadow-sm">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" /></svg>
            Call 0333 567 1654
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
